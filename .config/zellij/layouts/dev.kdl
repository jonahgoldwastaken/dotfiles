layout {
    tab focus=true name="nvim" {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        pane borderless=true command="fish" {
            args "-c" "nvim"
        }
    }
    tab name="term" {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        pane split_direction="vertical" {
            pane
            pane
        }
    }
    tab name="lazygit" {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        pane borderless=true command="lazygit"
    }
}

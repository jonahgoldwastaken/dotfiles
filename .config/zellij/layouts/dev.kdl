layout {
    tab focus=true name="nvim" {
        pane borderless=true command="nvim" args="."
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        } 
    }
    tab name="term" {
        pane split_direction="vertical" {
            pane
            pane
        }
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        } 
    }
    tab name="lazygit" {
        pane borderless=true command="lazygit"
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        } 
    }
}

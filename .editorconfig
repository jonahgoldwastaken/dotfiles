root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_size = tab
tab_width = 4
indent_style = space
trim trailing_whitespace = true
max_line_length = 80

[*.{yml,yaml,toml,md,mdx,json,jsonc,json5}]
indent_style = space
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false
max_line_length = off

[*.fish]
tab_width = 2
indent_size = 4
indent_style = space
